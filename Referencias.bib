@inbook{Cannataro2014,
   abstract = {Biological databases constitute the data layer of molecular biology and bioinformatics and are biological databasesequencebecoming a central component of some emerging fields such as clinical bioinformatics, and translational and personalized medicine. The building of biological databases has been conducted either considering the different representations of molecular entities, such as sequences and structures, or more recently by taking into account high-throughput platforms used to investigate cells and organisms, such as microarray and mass spectrometry technologies. This chapter provides an overview of the main biological databases currently available and underlines open problems and future trends.},
   author = {Mario Cannataro and Pietro H Guzzi and Giuseppe Tradigo and Pierangelo Veltri},
   city = {Berlin, Heidelberg},
   doi = {10.1007/978-3-642-30574-0_26},
   editor = {Nikola Kasabov},
   isbn = {978-3-642-30574-0},
   booktitle = {Springer Handbook of Bio-/Neuroinformatics},
   pages = {431-440},
   publisher = {Springer Berlin Heidelberg},
   title = {Biological Databases},
   url = {https://doi.org/10.1007/978-3-642-30574-0_26},
   year = {2014}
}
